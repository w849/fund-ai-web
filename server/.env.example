# 服务端口
PORT=3000

# CORS 允许的源（逗号分隔多个），生产环境必填，例如 http://localhost:5173,http://yourdomain.com
# 留空则允许所有来源（仅开发环境使用）
CORS_ORIGIN=http://localhost:5173

# 基金 API 基础地址（可替换为真实数据源）
FUND_API_BASE_URL=https://api.example.com

# 缓存时间（秒）
CACHE_TTL=300

# 日志级别
LOG_LEVEL=dev

# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Redis 配置（可选，未配置或不可用时自动降级到 node-cache 内存缓存）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
