# =====================================
# docker-compose 环境变量
# 复制此文件为 .env 并根据实际环境修改
# =====================================

# CORS 允许的源（生产环境必填）
CORS_ORIGIN=http://localhost:5173

# DeepSeek API 配置（不配置则自动降级到本地评分）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Redis 密码（可选）
REDIS_PASSWORD=

# 日志级别：dev/info/warn/error/silent
LOG_LEVEL=info
